# API
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
DATABASE_URL=postgresql+asyncpg://techsupport:techsupport@localhost:5433/techsupport
DATABASE_URL_SYNC=postgresql://techsupport:techsupport@localhost:5433/techsupport
REDIS_URL=redis://localhost:6380/0
REDIS_SESSION_TTL_SECONDS=86400

# Auth: dev = X-User-Id header; jwt = Bearer only
AUTH_MODE=dev
AUTH_DEV_HEADER_USER_ID=X-User-Id
# AUTH_JWT_SECRET=change-me-for-jwt-tests
# AUTH_JWT_AUDIENCE=

# Object store (MinIO local)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=attachments
S3_REGION=us-east-1

# LangGraph (Sprint 5+)
GRAPH_ENABLED=true
GRAPH_LLM_MODE=openai
# GRAPH_CHECKPOINT=true
# Ticketing provider: zammad (live) | servicenow (stub adapter)
TICKETING_PROVIDER=zammad

# OpenAI (direct — used when GRAPH_LLM_MODE=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # optional; leave unset for api.openai.com

# Live integration — AI User Simulator (optional; defaults to OPENAI_MODEL)
# USER_SIM_MODEL=gpt-4o-mini
# USER_SIM_TEMPERATURE=0.4
# INTEGRATION_MAX_TURNS=12
# Browser live tests only (make test-live-ui). Ignored by API-only make test-live.
# INTEGRATION_HEADLESS=false
# INTEGRATION_SLOW_MO=350             # ms pause between UI actions (browser mode)
# INTEGRATION_UI_PAUSE_MS=2500        # pause after ticket created (browser mode)
# LIVE_API_PORT=8020                  # ports for make test-live-ui
# LIVE_WEB_PORT=5175

# Web → API (local `make web`: leave unset, Vite proxies to localhost:8000)
# Docker Compose sets VITE_API_BASE_URL=http://localhost:8000 automatically
# VITE_API_BASE_URL=http://localhost:8000
# API_PROXY_TARGET=http://localhost:8000

# Zammad (sandbox — never commit real tokens)
# Local Zammad on host: use http://localhost:8080 for `make api` on the host.
# Docker Compose API rewrites localhost → host.docker.internal automatically.
ZAMMAD_BASE_URL=https://your-zammad.example.com
ZAMMAD_API_TOKEN=
ZAMMAD_TEST_EMAIL=your.name@company.com

