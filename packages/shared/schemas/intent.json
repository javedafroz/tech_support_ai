{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tech-support-ai.local/schemas/intent.json",
  "title": "StructuredIntent",
  "description": "Conversation Agent output; authoritative Zammad fields come from orchestration only.",
  "type": "object",
  "required": ["intent", "confidence", "session_id", "user_id", "payload", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "CreateTicket",
        "CheckStatus",
        "UpdateTicket",
        "AddAttachment",
        "EscalateIssue",
        "CancelTicket"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "intent": { "const": "CreateTicket" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "suggested_priority": { "type": "string" },
              "suggested_category": { "type": "string" },
              "customer_email": { "type": "string", "format": "email" },
              "attachments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["filename", "mime_type"],
                  "properties": {
                    "filename": { "type": "string" },
                    "mime_type": { "type": "string" },
                    "storage_key": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "intent": { "const": "CheckStatus" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "ticket_number": { "type": "string" },
              "search_hint": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
